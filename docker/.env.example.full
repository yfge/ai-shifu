REDIS_PORT="6379"

# Redis username
# (Optional - default: )
REDIS_USER=""


#============================================================
# Shifu
#============================================================

# Minimum price of shifu
# (Optional - default: 0.5)
# Type: float
MIN_SHIFU_PRICE="0.5"


#============================================================
# Storage
#============================================================

# Filesystem directory used for local storage provider (relative to app working dir if not absolute).
# (Optional - default: storage)
LOCAL_STORAGE_ROOT="storage"

# Storage provider for uploaded/generated files. Values: "auto" | "oss" | "local".
# (Optional - default: auto)
STORAGE_PROVIDER="auto"


#============================================================
# Testing
#============================================================

# Django settings module for testing
# (Optional - default: api.settings)
DJANGO_SETTINGS_MODULE="api.settings"


#============================================================
# Tts
#============================================================

# Aliyun AccessKey ID used to create temporary NLS tokens via OpenAPI (CreateToken)
# (Optional - default: )
# Secret value
ALIYUN_AK_ID=""

# Aliyun AccessKey Secret used to create temporary NLS tokens via OpenAPI (CreateToken)
# (Optional - default: )
# Secret value
ALIYUN_AK_SECRET=""

# Aliyun TTS Appkey from Intelligent Speech Interaction console
# (Optional - default: )
# Secret value
ALIYUN_TTS_APPKEY=""

# Aliyun TTS region (shanghai, beijing, shenzhen)
# (Optional - default: shanghai)
ALIYUN_TTS_REGION="shanghai"

# Aliyun TTS sample rate (8000, 16000, 24000)
# (Optional - default: 16000)
# Type: int
ALIYUN_TTS_SAMPLE_RATE="16000"

# Aliyun NLS access token (manual override; if empty the backend auto-fetches and caches a temporary token)
# (Optional - default: )
# Secret value
ALIYUN_TTS_TOKEN=""

# Baidu TTS API Key
# (Optional - default: )
# Secret value
BAIDU_TTS_API_KEY=""

# Baidu TTS Secret Key
# (Optional - default: )
# Secret value
BAIDU_TTS_SECRET_KEY=""

# Minimax API key for TTS synthesis
# (Optional - default: )
# Secret value
MINIMAX_API_KEY=""

# Minimax group ID for API access
# (Optional - default: )
MINIMAX_GROUP_ID=""

# TTS audio bitrate (32000-256000)
# (Optional - default: 128000)
# Type: int
MINIMAX_TTS_BITRATE="128000"

# TTS audio sample rate (8000-44100)
# (Optional - default: 24000)
# Type: int
MINIMAX_TTS_SAMPLE_RATE="24000"

# Maximum characters per TTS segment
# (Optional - default: 300)
# Type: int
TTS_MAX_SEGMENT_CHARS="300"

# Volcengine TTS access key/token (used by both WebSocket and HTTP providers)
# (Optional - default: )
# Secret value
VOLCENGINE_TTS_ACCESS_KEY=""

# Volcengine TTS app key/appid (used by both WebSocket and HTTP providers)
# (Optional - default: )
# Secret value
VOLCENGINE_TTS_APP_KEY=""

# Volcengine TTS audio bitrate
# (Optional - default: 128000)
# Type: int
VOLCENGINE_TTS_BITRATE="128000"

# Volcengine TTS cluster for HTTP v1/tts (e.g., volcano_tts)
# (Optional - default: volcano_tts)
VOLCENGINE_TTS_CLUSTER_ID="volcano_tts"

# Volcengine TTS audio sample rate (8000-48000)
# (Optional - default: 24000)
# Type: int
VOLCENGINE_TTS_SAMPLE_RATE="24000"


# ========== END OF CONFIGURATION ==========
# Remember to keep your .env file secure and never commit it to version control
